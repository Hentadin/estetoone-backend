# Application
NODE_ENV=development
PORT=3000
API_PREFIX=v1

# Database (PostgreSQL 16)
DATABASE_URL=postgresql://estetoone:estetoone_dev@localhost:5432/estetoone?schema=public

# Redis 7
REDIS_URL=redis://localhost:6379

# JWT (HEN-8 — auth module)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 (medical documents — Fase 3+)
AWS_REGION=sa-east-1
AWS_S3_BUCKET=estetoone-documents-dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Stripe (payments — Fase 3+)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Observability
SENTRY_DSN=
LOG_LEVEL=info
